# ── Gemini ───────────────────────────────────────────────────────────────
# Add as many keys as you have; the pool discovers GEMINI_API_KEY_1..N
# and gives each key exactly 5 consecutive calls before rotating.
GEMINI_API_KEY_1=
GEMINI_API_KEY_2=
GEMINI_MODEL=gemini-3.1-flash-lite
# Per-key requests/minute cap. Free tier flash-lite allows ~15 RPM per key;
# 10 leaves headroom for verify-call bursts. On a paid tier raise to 100+.
# The 5-calls-per-key rotation is never altered — the cap only delays calls.
GEMINI_MAX_RPM_PER_KEY=10

# ── Apache Kafka (event backbone) ────────────────────────────────────────
# BUS_DRIVER: kafka | redis. Defaults to kafka when KAFKA_BROKERS is set.
# Local dev: `docker compose up redpanda` gives you a broker on localhost:9092.
# Cloud (Render): use Redpanda Serverless / Confluent — set SASL + SSL below.
BUS_DRIVER=kafka
KAFKA_BROKERS=localhost:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=scram-sha-256
KAFKA_SSL=false

# ── Upstash Redis ─────────────────────────────────────────────────────────
# Does three jobs: durable result store (batches, scores, findings, per-URL
# history), live dashboard state, and the fallback event backbone when
# BUS_DRIVER=redis.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Auth ─────────────────────────────────────────────────────────────────
# Single-operator key — any long random string. Every caller (dashboard,
# curl, GitHub Actions) presents it as X-API-Key; the dashboard asks for it
# once and keeps it in localStorage.
INTERNAL_API_KEY=

# ── Notifications ────────────────────────────────────────────────────────
# Slack or Discord incoming-webhook URL; fired on batch completion.
# Can be overridden per batch at submission time.
WEBHOOK_URL=

# ── Tuning / rate limits ─────────────────────────────────────────────────
PORT=8080
MAX_NAV_STEPS=8
NAV_GOAL_TIMEOUT_MS=180000
# Worker stream-poll interval when idle. 5000ms keeps idle Upstash command
# spend at roughly a quarter of the 1.5s default while adding at most ~5s of
# pickup latency per stage — irrelevant for batch audits. Lower it only if
# you need snappier demo latency and accept the Upstash bill.
BUS_POLL_MS=5000
# Dashboard live-tail poll (API → Redis) in ms.
WS_TAIL_MS=2000
# Batch submission requests per caller per minute.
SUBMIT_RATE_LIMIT_PER_MIN=30
